# =============================================================================
# BJJ-BetSports - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y configura tus valores
#
# 🔧 SETUP RÁPIDO (Cualquier Máquina):
#    1. Ejecuta: ./scripts/setup-dev.sh
#    2. Copia este archivo: cp backend/.env.example backend/.env
# =============================================================================

# =============================================================================
# MODO DE ARQUITECTURA
# =============================================================================
# Producción (Render): API_ONLY_MODE=true (solo lee de DB, sin ML)
# Desarrollo local:    API_ONLY_MODE=false (ML habilitado)
API_ONLY_MODE=false

# =============================================================================
# BASE DE DATOS - SWITCH ENTRE AMBIENTES
# =============================================================================
#
# 🔄 SWITCHE DE PERSISTENCIA:
#
# ────────────────────────────────────────────────────────────────────────────
# OPCIÓN 1: MongoDB LOCAL (Modo Portable - RECOMENDADO PARA RÁPIDO SETUP)
# ────────────────────────────────────────────────────────────────────────────
# Requiere: docker compose -f docker-compose.dev.yml up -d
MONGO_URI=mongodb://admin:adminpassword@localhost:27017/
MONGO_DB_NAME=bjj_betsports

# ────────────────────────────────────────────────────────────────────────────
# OPCIÓN 2: PostgreSQL (Modo Producción / Robusto)
# ────────────────────────────────────────────────────────────────────────────
# ⚠️  CUIDADO: Se usa principalmente en despliegues reales (Render).
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bjj_betsports

# ────────────────────────────────────────────────────────────────────────────
# OPCIÓN 3: SQLite (Solo emergencias)
# ────────────────────────────────────────────────────────────────────────────
# Si DATABASE_URL y MONGO_URI están vacíos, se intenta usar SQLite.
# DATABASE_URL=

# =============================================================================
# API KEYS
# =============================================================================
# Optional: Football-Data.org key (free tier: 10 requests/min)
# Get your key at: https://football-data.org/client/register
FOOTBALL_DATA_ORG_KEY=

# Optional: The Odds API key
# Get your key at: https://the-odds-api.com
THE_ODDS_API_KEY=

# Optional: RapidAPI key
RAPIDAPI_KEY=

# Optional: TheSportsDB key (free tier: uses '3')
THESPORTSDB_KEY=3

# --- Seguridad API ---
# Admin API key para endpoints protegidos (no commitear valores reales)
ADMIN_API_KEY=cambiar-por-un-valor-aleatorio-seguro

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Frontend URL for CORS (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Server port
PORT=8000

# Debug mode (set to 'true' for development)
DEBUG=false

# =============================================================================
# WORKER CONFIGURATION (for GitHub Actions / local worker script)
# =============================================================================
# Set to 'true' to disable ML training (useful for testing)
DISABLE_ML_TRAINING=false

# Memory mode (set to 'true' for low-memory environments)
LOW_MEMORY_MODE=false

# Clear cache on startup (useful for development)
CLEAR_CACHE_ON_START=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

